{
  "name": "mechvibes",
  "productName": "Mechvibes",
  "version": "v2.3.9",
  "description": "Play mechanical keyboard sounds as you type.",
  "repository": "https://github.com/hainguyents13/mechvibes",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsgo",
    "dev": "npm run build && electron .",
    "build:all": "npm run build && electron-builder -wml",
    "build:win": "npm run build && electron-builder -w",
    "build:mac": "npm run build && electron-builder -m",
    "build:linux": "npm run build && electron-builder -l",
    "build:clean": "node tools/clean-dist.js"
  },
  "keywords": [],
  "homepage": "https://mechvibes.com",
  "author": {
    "name": "Hai Nguyen",
    "email": "hainguyen.ts13@gmail.com"
  },
  "license": "MIT",
  "build": {
    "extraResources": [
      {
        "from": "audio",
        "to": "audio"
      },
      {
        "from": "src/renderer",
        "to": "src/renderer",
        "filter": ["**/*.html", "**/*.css"]
      },
      {
        "from": "src/assets",
        "to": "src/assets"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "./build/installer.nsh"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "category": "Utility",
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "snap",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.png"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "better-result": "^2.8.2",
    "easy-volume": "^1.2.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "howler": "^2.2.4",
    "mime-types": "^3.0.2",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/fs-extra": "^11.0.4",
    "@types/howler": "^2.2.12",
    "@types/jquery": "^4.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260419.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "uiohook-napi"
  ]
}
